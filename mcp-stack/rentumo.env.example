# Rentumo Trials MCP secrets. Copy to rentumo.env (gitignored) and fill in.
#   cp rentumo.env.example rentumo.env
# Do NOT commit the real rentumo.env (.gitignore already ignores *.env).

# Shared admin bearer token — works across every market's /api/admin/charts.
# This is the ONLY credential; there is no per-user OAuth (Thribee-style model).
# Rotate by editing this file and redeploying compose.rentumo.yaml.
RENTUMO_BEARER_TOKEN=YOUR_RENTUMO_ADMIN_BEARER_TOKEN

# The 26 market codes + admin domains are NOT in this file — they live in
# markets.json on the rentumo_data volume, mounted at /data/markets.json.
# Seed it from ../rentumo-trials-mcp/markets.example.json (see that README).
# Override the path only if you mount it elsewhere:
# RENTUMO_MARKETS_FILE=/data/markets.json

# Optional tuning:
# RENTUMO_MAX_CONCURRENCY=12
# RENTUMO_REQUEST_TIMEOUT=30
