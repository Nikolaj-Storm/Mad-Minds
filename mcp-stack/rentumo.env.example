# Rentumo Trials MCP secrets. Copy to rentumo.env (gitignored) and fill in.
#   cp rentumo.env.example rentumo.env
# Do NOT commit the real rentumo.env (.gitignore already ignores *.env).

# Shared admin bearer token — works across every market's /api/admin/charts.
# This is the ONLY credential and the ONLY thing you must set here; there is no
# per-user OAuth (Thribee-style model). Rotate by editing this file and
# redeploying compose.rentumo.yaml. NEVER commit the real value.
RENTUMO_BEARER_TOKEN=YOUR_RENTUMO_ADMIN_BEARER_TOKEN

# The 26 market codes + admin domains are BUNDLED in the image
# (rentumo-trials-mcp/src/rentumo_trials_mcp/markets.json) — no seeding needed.
# Only set this to override the bundled list with a file on the /data volume:
# RENTUMO_MARKETS_FILE=/data/markets.json

# Optional tuning:
# RENTUMO_MAX_CONCURRENCY=12
# RENTUMO_REQUEST_TIMEOUT=30
