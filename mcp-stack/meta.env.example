# Meta Ads MCP secrets — ONE file per Facebook app / business area.
# Copy this to BOTH:
#   cp meta.env.example meta-onlineminds.env   # "Mad Minds MCP onlineminds.io" app
#   cp meta.env.example meta-rentumo.env       # "Mad Minds MCP Rentumo aps" app
# then fill each with that app's own credentials + its own base URL.
# Do NOT commit the real *.env files (.gitignore already ignores *.env).

META_APP_ID=1234567890
META_APP_SECRET=your_app_secret_here

# Each instance's own Tailscale Funnel hostname. Must match that Facebook app's
# redirect-URI host (https://<host>/auth/callback):
#   meta-onlineminds.env -> https://meta-onlineminds.<your-tailnet>.ts.net
#   meta-rentumo.env     -> https://meta-rentumo.<your-tailnet>.ts.net
META_OAUTH_BASE_URL=https://meta-onlineminds.<your-tailnet>.ts.net

META_SCOPES=ads_read,ads_management

# Facebook Login for Business: new "Business" apps only offer "Facebook Login for
# Business" (classic "Facebook Login" is retired), which rejects the scope-based
# flow ("Missing authorization code"). Fix: in the app, Facebook Login for
# Business -> Configurations -> create a config granting ads_read + ads_management,
# then paste its Configuration ID here. The server then uses config_id instead of
# scope. Leave blank only if your app has classic Facebook Login.
# META_CONFIG_ID=1234567890123456

# Pin to a currently-supported Graph API version; bump when Meta retires it:
META_GRAPH_VERSION=v21.0
CLIENT_STORAGE_DIR=/data
# Generate once with: openssl rand -hex 32   (keep it stable or everyone re-Connects)
JWT_SIGNING_KEY=replace_me
# Writes SIMULATE until this is false (and even then go through /ad-actions):
READONLY_MODE=true
# Optional default account so marketers don't pass act_... every time:
# META_AD_ACCOUNT_ID=act_1234567890
