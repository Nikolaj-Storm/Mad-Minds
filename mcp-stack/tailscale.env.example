# Tailscale auth key. Copy to tailscale.env (gitignored) and paste your key.
#
# In the Tailscale admin console (login.tailscale.com), one-time:
#   1. DNS tab -> Enable HTTPS (needed for the Funnel cert).
#   2. Access Controls -> add a Funnel node-attribute policy (see README.md).
#   3. Settings -> Keys -> Generate auth key (Reusable is convenient). Paste below.
#
# The node identity persists in the ts_state volume, so the key is only used on
# first start.
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxxxxxx
