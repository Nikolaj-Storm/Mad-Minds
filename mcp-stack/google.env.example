# Google MCP secrets — ONE file per server. Copy to BOTH:
#   cp google.env.example gads.env   # Google Ads server
#   cp google.env.example gsc.env    # Search Console server
# then fill each with that server's own OAuth client + base URL.
# Do NOT commit the real *.env files (.gitignore already ignores *.env).

# FastMCP's built-in Google OAuth-proxy provider:
FASTMCP_SERVER_AUTH=fastmcp.server.auth.providers.google.GoogleProvider
FASTMCP_SERVER_AUTH_GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
FASTMCP_SERVER_AUTH_GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_SECRET

# Scopes — pick the line for this server:
#   Google Ads:      openid,https://www.googleapis.com/auth/userinfo.email,https://www.googleapis.com/auth/adwords
#   Search Console:  openid,https://www.googleapis.com/auth/userinfo.email,https://www.googleapis.com/auth/webmasters.readonly
FASTMCP_SERVER_AUTH_GOOGLE_REQUIRED_SCOPES=openid,https://www.googleapis.com/auth/userinfo.email,https://www.googleapis.com/auth/adwords

# Each server's own Tailscale Funnel hostname. MUST match that OAuth client's
# redirect-URI host (https://<host>/auth/callback):
#   gads.env -> https://gads.<your-tailnet>.ts.net
#   gsc.env  -> https://gsc.<your-tailnet>.ts.net
FASTMCP_SERVER_AUTH_GOOGLE_BASE_URL=https://gads.<your-tailnet>.ts.net

# Disk-backed token store (this volume is mounted at /data in compose.google.yaml)
# so marketers sign in once and survive restarts/redeploys:
CLIENT_STORAGE_DIR=/data
# Generate once with: openssl rand -hex 32 (keep it stable or everyone re-Connects)
JWT_SIGNING_KEY=replace_me

# --- Google Ads ONLY ---
# Basic-Access developer token (one for the whole org). Reads/writes return no
# live data until a real token is present.
GOOGLE_ADS_DEVELOPER_TOKEN=YOUR_BASIC_ACCESS_DEV_TOKEN
# Writes SIMULATE until this is false (and even then go through /ad-actions):
READONLY_MODE=true
# Optional, if accounts sit under a manager (MCC):
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# (GSC needs neither GOOGLE_ADS_* line; delete them from gsc.env.)
