# Meta Ads MCP — environment. Copy to .env and fill in. NEVER commit .env.
# =============================================================================
# Legend:  [YOU MUST SET]  = only you can provide (no safe default)
#          [HAS DEFAULT]   = fine as-is; override only if you have a reason
# =============================================================================

# --- Facebook App: the org-level server secret (OAuth-handshake credential) ---
# [YOU MUST SET] Create at https://developers.facebook.com/ -> your app ->
# Settings > Basic. This is the Meta analogue of the Google Ads developer token,
# EXCEPT it is only used during sign-in, never attached to individual API calls.
META_APP_ID=
META_APP_SECRET=

# [YOU MUST SET] Public HTTPS base URL your reverse proxy serves (NO trailing
# slash). Must match the OAuth redirect URI whitelisted in the Facebook app:
#   <META_BASE_URL>/auth/callback
# e.g. https://meta-mcp.onlineminds.io
META_BASE_URL=

# --- Safe defaults (override only if needed) ---------------------------------

# [HAS DEFAULT] Scopes the marketer grants at sign-in. ads_read = reporting;
# ads_management = pause/enable + budget writes. (business_management optional,
# only for some Business-Manager-scoped reads.)
META_REQUIRED_SCOPES=ads_read,ads_management

# [HAS DEFAULT] Graph API version. v25.0 is the newest live version as of
# 2026-06. Bump deliberately when Meta deprecates one, then re-test.
GRAPH_API_VERSION=v25.0

# [HAS DEFAULT] Where persisted per-user sign-ins are stored. docker-compose
# mounts the named volume here and also sets this var, so sign-ins survive
# restarts. Leave as /data when using the provided compose file.
CLIENT_STORAGE_DIR=/data

# [HAS DEFAULT] Safety: writes SIMULATE until this is "false". Reads work
# regardless. Real writes are ALSO gated by the /ad-actions spend-gate in Mad
# Minds. Keep "true" until you've verified the connector end-to-end.
READONLY_MODE=true

# --- Recommended (optional) --------------------------------------------------

# [OPTIONAL] Stable signing key for issued session tokens so marketers stay
# signed in across container restarts/redeploys. Generate once and keep it:
#   openssl rand -hex 32
# If unset, the server uses an ephemeral key (sign-ins drop on restart).
JWT_SIGNING_KEY=

# [OPTIONAL] Default ad account so marketers don't pass account_id every time
# (digits, with or without the act_ prefix). Most teams LEAVE THIS UNSET and let
# list_accounts drive it, since each marketer has different accounts.
# META_AD_ACCOUNT_ID=
